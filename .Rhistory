head(secuencia_sectores)
write_parquet(secuencia_sectores, "./materiales/secuencia_sectores_edad_mujeres.parquet")
ds_original_muj <- ds_original
rm(ds_original)
secuencia_sectores_muj <- secuencia_sectores
rm(secuencia_sectores)
