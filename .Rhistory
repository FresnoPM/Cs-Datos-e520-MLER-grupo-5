alfabeto_sectores
# # Asignamos una paleta de colores bien contrastante para que se distingan en el gráfico
colores_sectores <- paletteer_d(package = "pals", palette = "alphabet", n = 17)
# # Asignamos una paleta de colores bien contrastante para que se distingan en el gráfico
colores_sectores <- paletteer_d("pals::alphabet", n = 17)
colores_sectores
