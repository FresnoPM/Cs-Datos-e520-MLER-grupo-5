# A function that expects a single data frame row
my_function <- function(row) {
inicio <- as.Date( row["inicio"])
fin <- row["fin"]
enero <- update(inicio, year = year(inicio) + 1, month = 1, day = 1)
diciembre <- update(inicio, year = year(inicio) + 12, month = 1, day = 1)
result <- data.frame(inicio = Date())
while ( row["fin"] > row["inicio"] ) {
#print(enero)
result %>% add_row( inicio = enero)
enero <- enero %m+% years(1)
}
typeof(result)
return(result)
}
output <- apply(inicio_fin, 1, my_function)
