calculo_nuevos_nodos <- function(d){
new_rows <- data.frame(orig_id = numeric(), id_trabajador = numeric() , tiempo = Date(), r34 = numeric())
for (i in 1:nrow(d)) {
# Access data from the current row
orig_id <- inicio_fin[i, "orig_id"][[1]]
id_trabajador <- inicio_fin[i, "id_trabajador"][[1]]
inicio <- as.Date( inicio_fin[i, "inicio"][[1]])
fin <- as.Date( inicio_fin[i, "fin"][[1]])
enero <- update(inicio, year = year(inicio) + 1, month = 1, day = 1)
while (fin > enero) {
new_item <- data.frame(
orig_id = orig_id,
id_trabajador = id_trabajador,
tiempo = enero,
r34 = 999
)
new_rows <- new_rows %>% add_row (new_item)
enero = ymd(enero) %m+% years(1)
}
diciembre <- update(inicio, year = year(inicio) + 1, month = 12, day = 1)
while (fin > diciembre) {
new_item <- data.frame(
orig_id = orig_id,
id_trabajador = id_trabajador,
tiempo = diciembre,
r34 = 999
)
new_rows <- new_rows %>% add_row (new_item)
diciembre = ymd(diciembre) %m+% years(1)
}
#
}
return(new_rows)
}
