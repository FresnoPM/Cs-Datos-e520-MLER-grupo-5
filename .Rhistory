crear_secuencia <- function(ds, muestra=0){
df_sectores_edad <- ds %>%
select(
id_trabajador #, tiempo
,letra
,nodo
,edad
) %>%
filter(edad <= 50) %>%
distinct(id_trabajador, edad, .keep_all = TRUE) %>%
collect() %>%
select(
id_trabajador # , tiempo
,nodo
,edad
)
relleno <- "Fuera"
alfabeto_sectores <- c(unique(df_sectores_edad$nodo), relleno)
df_secuencias <- df_sectores_edad %>%
pivot_wider( # tidyverse
names_from = edad,
values_from = nodo,
values_fill = relleno,
names_sort = TRUE # Mantenemos la corrección de edades
) %>%
arrange(id_trabajador)
matriz_estados <- as.data.frame(df_secuencias %>% select(-id_trabajador))
secuencia_sectores <- seqdef(
data = matriz_estados,
alphabet = alfabeto_sectores,
states = alfabeto_sectores,
id = df_secuencias$id_trabajador
)
if(muestra!=0){ secuencia_sectores <- sample(1:nrow(secuencia_sectores), muestra)}
return(secuencia_sectores)
}
secuencia_sectores <- crear_secuencia(ds_original, muestra = 150)
########################3
matriz_transiciones <- seqtrate(secuencia_sectores)
ecuencia_sectores
secuencia_sectores
secuencia_sectores <- crear_secuencia(ds_original)
matriz_transiciones
