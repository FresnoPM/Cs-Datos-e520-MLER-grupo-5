}
return(df_sectores)
}
library(dplyr)
library(data.table)
library(tidyverse)
library(arrow)
library(TraMineR)
library(ggseqplot)
selecciono_por_edad <- function(ds,
edad_min = 17,
edad_max = 50,
cantidad=0,
debug=FALSE){
df_sectores <- ds %>%
filter(!is.na(edad) & .$edad <= edad_max & .$edad >= edad_min) %>%
select(id_trabajador
, tiempo
#, rem_tot_real
, edad
, letra
, nodo) %>%
distinct(id_trabajador, tiempo, .keep_all = TRUE) %>%
collect() %>%
setDT()
if(cantidad != 0){
df_sectores <- df_sectores %>% filter( .$id_trabajador %in% sample( unique(.$id_trabajador), size = cantidad )  )
}
if(debug==TRUE){
print(class(df_sectores))
print(nrow(df_sectores))
}
return(df_sectores)
}
#ds_original_muj <- open_dataset("./materiales/MLER_mujeres.parquet", format = "parquet")
sexo = "Mujeres"
ds_original_muj <- open_dataset("./materiales/MLER_mujeres.parquet", format = "parquet")
df_sectores_edad <- selecciono_por_edad(ds_original_muj, cantidad=15, debug=TRUE)
df_sectores <- df_sectores %>% filter( df_sectores$id_trabajador %in% sample( unique(.$id_trabajador), size = cantidad )  )
