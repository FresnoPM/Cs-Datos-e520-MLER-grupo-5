library(ggraph)
packageVersion("ggraph")
library(ggraph)
library(igraph)
library(tidyverse)
# Assign vertex colors from colores_sectores
V(red_sectores)$color <- colores_sectores
# Clean vertex labels: remove "[-> " prefix and "]" suffix
V(red_sectores)$label <- V(red_sectores)$name |>
str_remove("^\\[-> ") |>
str_remove("\\]$")
# Filter out self-loops and very weak edges for clarity
red_plot <- delete_edges(red_sectores, which(E(red_sectores)$weight < 0.02))
red_plot <- simplify(red_plot, remove.loops = TRUE)
ggraph(red_plot, layout = "fr") +
geom_edge_arc(
aes(width = weight, alpha = weight),
arrow = arrow(length = unit(2, "mm"), type = "closed"),
end_cap = circle(3, "mm"),
color = "grey40",
strength = 0.15
) +
geom_node_point(
aes(color = I(color)),
size = 5
) +
geom_node_text(
aes(label = label),
repel = TRUE,
size = 2.5,
color = "grey10",
max.overlaps = 20
) +
scale_edge_width(range = c(0.3, 3), guide = "none") +
scale_edge_alpha(range = c(0.2, 0.9), guide = "none") +
labs(
title = paste("Red de transiciones sectoriales —", sexo),
subtitle = "Aristas: probabilidad de transición ≥ 2%"
) +
theme_graph(base_family = "sans") +
theme(
plot.title = element_text(size = 14, face = "bold"),
plot.subtitle = element_text(size = 10, color = "grey40")
)
ggraph(red_plot, layout = "fr") +
geom_edge_arc(
aes(width = weight
