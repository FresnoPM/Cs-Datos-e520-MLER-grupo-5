cat("cpal:\n"); print(cpal(secuencia_sectores_muj_edad))
cat("\nalphabet:\n"); print(alphabet(secuencia_sectores_muj_edad))
ls("package:ggseqplot")
stat_d       <- seqstatd(secuencia_sectores_muj_edad)
df_freq      <- as.data.frame(stat_d$Frequencies)
state_colors <- setNames(cpal(secuencia_sectores_muj_edad),
alphabet(secuencia_sectores_muj_edad))
df_heat <- df_freq |>
rownames_to_column("state") |>
pivot_longer(-state, names_to = "position", values_to = "prop") |>
mutate(
age   = as.integer(str_extract(position, "\\d+")),
state = factor(state, levels = rev(alphabet(secuencia_sectores_muj_edad)))
)
# Y-axis label colors: match each state level to its color
label_colors <- state_colors[levels(df_heat$state)]
ggplot(df_heat, aes(x = age, y = state, fill = prop)) +
geom_tile() +
scale_fill_gradient(low = "white", high = "#1d1d1d", name = "Proporción") +
scale_x_continuous(breaks = seq(17, 50, by = 5)) +
labs(
title = paste("Distribución de estados por edad -", sexo, "(1996-2021)"),
x     = "Edad",
y     = NULL
) +
theme_minimal(base_size = 11) +
theme(
panel.grid       = element_blank(),
axis.text.y      = element_text(color = label_colors)
)
ggplot(df_heat, aes(x = age, y = state, fill = prop)) +
geom_tile() +
scale_fill_viridis_c(option = "turbo", name = "Proporción") +
scale_x_continuous(breaks = seq(17, 50, by = 5)) +
labs(
title = paste("Distribución de estados por edad -", sexo, "(1996-2021)"),
x     = "Edad",
y     = NULL
) +
theme_minimal(base_size = 10) +
theme(
panel.grid  = element_blank(),
axis.text.y = element_text(color = label_colors, size = 7)
)
# Peek at row/col names to make sure alignment is right
rownames(matriz_transiciones)[1:5]
colnames(matriz_transiciones)[1:5]
# Clean state names (strip TraMineR brackets)
states_clean <- alphabet(secuencia_sectores)
state_colors_map <- setNames(cpal(secuencia_sectores), states_clean)
# Convert to long format, set diagonal to NA, apply threshold
mat <- matriz_transiciones
diag(mat) <- NA
df_trans <- as.data.frame(mat) |>
setNames(states_clean) |>
mutate(from = states_clean) |>
pivot_longer(-from, names_to = "to", values_to = "prob") |>
filter(is.na(prob) | prob >= tolerancia_peso)
state_order <- states_clean
ggplot(df_trans, aes(x = to, y = from, fill = prob)) +
geom_tile(color = "white", linewidth = 0.3) +
scale_fill_viridis_c(
option   = "turbo",
na.value = "grey92",
name     = "Prob.\ntransición"
) +
scale_x_discrete(limits = state_order) +
scale_y_discrete(limits = rev(state_order)) +
labs(
title = paste("Matriz de Transiciones Sectoriales -", sexo, "(1996-2021)"),
x     = "Hacia →",
y     = "Desde ↑"
) +
theme_minimal(base_size = 10) +
theme(
axis.text.x = element_text(
angle = 45, hjust = 1,
color = state_colors_map[state_order], size = 6
),
axis.text.y = element_text(
color = state_colors_map[rev(state_order)], size = 6
),
panel.grid  = element_blank()
)
