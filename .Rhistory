) %>%  # fin rbind
arrange(desc(id_trabajador), tiempo) # ordeno para que se intercalen como corresponde porque rbind pone los uncount nuevos al final de todo
rm(transicion_letra_volver)
# rm(transicion_letra_volver)
transicion_letra_volver <- rbind(transicion_letra, uncount(
transicion_letra %>%
filter( intervalo >= as.numeric(tolerancia),
intervalo != 999
) # fin filter
, 1) %>%  # fin uncount
mutate (
id_relacion = 999,
letra = 999,
# sig_letra = dplyr::lead(letra, default = 0),
r32 = 999,
r34 = 999,
edad = round(as.numeric(edad)+(as.numeric(intervalo)/12), digits = 0),
n = intervalo,
tiempo = ymd(as.Date(tiempo)) %m+% months(as.numeric(intervalo-1))
) %>%
mutate(
intervalo = 1,  # cambio  intervalo a 1 porque es lo que tarda desde el mes anterior a volver hasta el mes a volver
) # hasta acá trabajamos sólo con las nuevas rows que van a ser bindeadas al final
) %>%  # fin rbind
arrange(desc(id_trabajador), tiempo) %>% # ordeno para que se intercalen como corresponde porque rbind pone los uncount nuevos al final de todo
mutate( ifelse( intervalo >= as.numeric(tolerancia), sig_letra = 999)) # ajusto  la transición hacia afuera del sistema
# rm(transicion_letra_volver)
transicion_letra_volver <- rbind(transicion_letra, uncount(
transicion_letra %>%
filter( intervalo >= as.numeric(tolerancia),
intervalo != 999
) # fin filter
, 1) %>%  # fin uncount
mutate (
id_relacion = 999,
letra = 999,
# sig_letra = dplyr::lead(letra, default = 0),
r32 = 999,
r34 = 999,
edad = round(as.numeric(edad)+(as.numeric(intervalo)/12), digits = 0),
n = intervalo,
tiempo = ymd(as.Date(tiempo)) %m+% months(as.numeric(intervalo-1))
) %>%
mutate(
intervalo = 1,  # cambio  intervalo a 1 porque es lo que tarda desde el mes anterior a volver hasta el mes a volver
) # hasta acá trabajamos sólo con las nuevas rows que van a ser bindeadas al final
) %>%  # fin rbind
arrange(desc(id_trabajador), tiempo) %>% # ordeno para que se intercalen como corresponde porque rbind pone los uncount nuevos al final de todo
mutate(sig_letra = ifelse( intervalo >= as.numeric(tolerancia), 999, sig_letra)) # ajusto  la transición hacia afuera del sistema
View(transicion_letra_volver)
# --------- Interpretación de cada línea ---------
transicion_letra_volver <- transicion_letra_volver %>% mutate(interpretacion = case_when(
letra != sig_letra & intervalo == 0 ~ "tiene otro trabajo de otra letra en el mismo periodo",
letra == sig_letra & intervalo == 0 ~ "tiene otro trabajo de la misma letra en el mismo periodo",
sig_letra == 999 & intervalo == 999 ~ paste("sale del sistema definitivamente luego de realizar aportes por ", total_aportes, " meses"),
letra != sig_letra & intervalo != 999 ~ paste("sale del sistema por ", intervalo, " meses y cambia de letra"),
letra == 999 ~ paste("vuelve al sistema después de ", lag(intervalo), " meses" ),
letra == sig_letra & intervalo == 1 ~ "continúa en la misma letra",
letra == sig_letra & intervalo != 1 ~ paste("sale del sistema por ", intervalo, " meses pero vuelve a la misma letra"),
letra != sig_letra & intervalo == 1 ~ "transiciona de letra sin intervalo en el medio"
)
)
# --------- Interpretación de cada línea ---------
transicion_letra_volver <- transicion_letra_volver %>% mutate(interpretacion = case_when(
letra != sig_letra & intervalo == 0 ~ "tiene otro trabajo de otra letra en el mismo periodo",
letra == sig_letra & intervalo == 0 ~ "tiene otro trabajo de la misma letra en el mismo periodo",
sig_letra == 999 & intervalo == 999 ~ paste("sale del sistema definitivamente luego de realizar aportes por ", total_aportes, " meses"),
letra == 999 & letra != sig_letra   ~ paste("vuelve al sistema después de ", lag(intervalo), " meses" ),
letra == sig_letra & intervalo == 1 ~ "continúa en la misma letra",
letra == sig_letra & intervalo != 1 ~ paste("sale del sistema por ", intervalo, " meses pero vuelve a la misma letra"),
letra != sig_letra & intervalo == 1 ~ "transiciona de letra sin intervalo en el medio"
)
)
# --------- Interpretación de cada línea ---------
transicion_letra_volver <- transicion_letra_volver %>% mutate(interpretacion = case_when(
letra != sig_letra & intervalo == 0 ~ "tiene otro trabajo de otra letra en el mismo periodo",
letra == sig_letra & intervalo == 0 ~ "tiene otro trabajo de la misma letra en el mismo periodo",
letra == sig_letra & intervalo == 1 ~ "continúa en la misma letra",
letra != sig_letra & intervalo == 1 ~ "continua con otra letra",
sig_letra == 999 & intervalo == 999 ~ paste("sale del sistema definitivamente luego de realizar aportes por ", total_aportes, " meses"),
letra == 999 ~ paste("vuelve al sistema después de ", dplyr::lag(intervalo), " meses" ),
letra == sig_letra & intervalo != 1 ~ paste("sale del sistema por ", intervalo, " meses")
)
)
# --------- Interpretación de cada línea ---------
transicion_letra_volver <- transicion_letra_volver %>% mutate(interpretacion = case_when(
sig_letra == 999 & intervalo == 999 ~ paste("sale del sistema definitivamente luego de realizar aportes por ", total_aportes, " meses"),
sig_letra == 999                    ~ paste("sale del sistema por los próximos ", intervalo, " meses"),
letra == 999                        ~ paste("vuelve al sistema después de ", dplyr::lag(intervalo), " meses" ),
intervalo == 0                      ~ "tiene otro trabajo en el mismo periodo",
letra == sig_letra & intervalo == 1 ~ "continúa en la misma letra",
letra != sig_letra & intervalo == 1 ~ "continua con otra letra",
)
)
saveRDS(transicion_letra_volver, file = "materiales/df_mujer_transicion.rds")
View(transicion_letra_volver)
