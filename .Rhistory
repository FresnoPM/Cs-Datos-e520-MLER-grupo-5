filter(str_detect(estado_destino, "Fuera|Pausa")) %>%
mutate(sector = str_remove(estado_origen, "^Activo: ")) %>%
group_by(sector) %>%
summarise(tasa_fuga_control = sum(weight) * 100)
fuga_mamis <- red_mamis %>%
