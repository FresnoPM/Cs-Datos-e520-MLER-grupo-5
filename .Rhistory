group_by(estado_origen) %>%
mutate(weight = weight / sum(weight)) %>%
ungroup() %>%
arrange(desc(weight))
graficar_red_comparativa <- function(edgelist, datos_crudos, titulo_grafico) {
# 1. Calculamos la "cantidad de mujeres" real para el tamaño del nodo
volumen_destino <- datos_crudos %>%
count(estado_destino, name = "cantidad") %>%
rename(name = estado_destino)
volumen_origen <- datos_crudos %>%
count(estado_origen, name = "cantidad") %>%
rename(name = estado_origen)
volumen_nodos <- bind_rows(volumen_destino, volumen_origen) %>%
group_by(name) %>%
summarise(cantidad_mujeres = max(cantidad), .groups = "drop")
# 2. Creamos el objeto de red inicial
grafo <- graph_from_data_frame(edgelist, directed = TRUE)
tolerancia_peso <- 0.02
grafo <- delete_edges(grafo, which(E(grafo)$weight < tolerancia_peso))
# 3. Inyectamos los atributos visuales (Con escudo anti-NAs)
cantidades_match <- volumen_nodos$cantidad_mujeres[match(V(grafo)$name, volumen_nodos$name)]
V(grafo)$cantidad_mujeres <- replace_na(cantidades_match, 1) # Escudo protector
V(grafo)$label <- V(grafo)$name %>%
str_remove("^\\[-> ") %>%
str_remove("\\]$")
V(grafo)$categoria <- case_when(
str_detect(V(grafo)$label, "Fuera") ~ "Fuera del Sistema",
str_detect(V(grafo)$label, "Pausa") ~ "Pausa",
str_detect(V(grafo)$label, "^Licencia") ~ "Licencia",
str_detect(V(grafo)$label, "^Activo") ~ "Activo",
TRUE ~ "Otros"
)
# 4. Paleta de Colores
paleta_colores <- c(
"Activo" = "#2a9d8f",
"Licencia" = "#e9c46a",
"Pausa" = "#8d99ae",
"Fuera del Sistema" = "#e76f51",
"Otros" = "grey50"
)
# 5. Renderizado final corregido
ggraph(grafo, layout = "fr") +
# FIX ARISTAS: Volvemos a usar 'width = weight' dentro de aes()
geom_edge_arc(
aes(width = weight
#, alpha = weight
), # Acá estaba el colapso
arrow = arrow(length = unit(4, "mm"), type = "closed"),
start_cap = circle(5, "mm"),
end_cap = circle(6, "mm"),
color = "grey50",
strength = 0.25
) +
geom_node_point(
aes(color = categoria, size = cantidad_mujeres)
) +
geom_node_text(
aes(label = label),
repel = TRUE,
size = 3.5,
color = "grey15",
fontface = "bold",
max.overlaps = 30
) +
scale_color_manual(values = paleta_colores) +
scale_size_continuous(range = c(3, 16)) +
scale_edge_width(range = c(0.4, 2.5), guide = "none") +
# scale_edge_alpha(range = c(0.4, 0.9), guide = "none") +
labs(
title = titulo_grafico,
subtitle = paste("Aristas: probabilidad transicion >= ", tolerancia_peso),
color = "Estado Laboral",
size = "Cantidad de Mujeres"
) +
theme_graph(base_family = "sans") +
theme(
plot.title = element_text(size = 14, face = "bold"),
plot.subtitle = element_text(size = 10, color = "grey40"),
legend.position = "bottom",
legend.box = "vertical",
legend.margin = margin(t = 10)
)
}
# Ejecución (Ahora sí van a renderizar)
grafico_control <- graficar_red_comparativa(red_control, control_procesado, "Control (No Madres) t=36")
grafico_tratamiento <- graficar_red_comparativa(red_mamis, mamis_procesadas, "Tratamiento (Madres) t=36")
