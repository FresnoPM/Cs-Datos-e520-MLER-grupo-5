library(dplyr)
col_name <- "new_revenue"
# Creating a new dynamically named column
df <- df %>%
mutate("{col_name}" := sales * price)
# Create a standard dummy dataframe
dummy_df <- data.frame(
id = 1:5,
group = sample(c("Treatment", "Control"), 5, replace = TRUE),
age = c(23, 45, 31, 19, 52),
score = round(rnorm(5, mean = 75, sd = 10), 1)
)
# Print the result
print(dummy_df)
col_name <- "new_revenue"
# Creating a new dynamically named column
df <- dummy_df %>%
mutate("{col_name}" := age * score)
# Renaming an existing column dynamically
df <- df %>%
rename("{col_name}" := group)
df
# Renaming an existing column dynamically
df <- df %>%
rename("{col_name}" := age)
col_name <- "nombrecito"
# Renaming an existing column dynamically
df <- df %>%
rename(group  := "{col_name_2}")
# Creating a new dynamically named column
df <- dummy_df %>%
mutate("{col_name}" := age * score,
"{col_name_2}" := [1,5])
# Creating a new dynamically named column
df <- dummy_df %>%
mutate("{col_name}" := age * score,
"{col_name_2}" := c([1,5]))
# Creating a new dynamically named column
df <- dummy_df %>%
mutate("{col_name}" := age * score,
"{col_name_2}" := c(a,b,c,d,e))
col_name <- "new_revenue"
col_name_2 <- "nombrecito"
# Creating a new dynamically named column
df <- dummy_df %>%
mutate("{col_name}" := age * score,
"{col_name_2}" := c(a,b,c,d,e))
# Creating a new dynamically named column
df <- dummy_df %>%
mutate("{col_name}" := age * score,
"{col_name_2}" := c(1,2,3,4,5))
# Renaming an existing column dynamically
df <- df %>%
rename(group  := "{col_name_2}")
df
# Renaming an existing column dynamically
df <- df %>%
rename("{col_name_2}" := "algo")
# Renaming an existing column dynamically
df <- df %>%
rename(algo = "{col_name_2}")
# Renaming an existing column dynamically
df <- df %>%
rename(algo =: "{col_name_2}")
# Renaming an existing column dynamically
df <- df %>%
rename(algo := "{col_name_2}")
df
# Renaming an existing column dynamically
df <- df %>%
mutate("{col_name_2}" := "{col_name_2}"*2)
# Renaming an existing column dynamically
df <- df %>%
mutate("{col_name_2}" := df[[col_name_2]]*2)
df
